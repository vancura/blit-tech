{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "language": "en",
  "allowCompoundWords": true,
  "dictionaries": ["typescript", "node", "html", "css", "fonts", "npm", "softwareTerms"],
  "words": [
    "ABGR",
    "antialiasing",
    "bgra",
    "bindgroup",
    "bindgroups",
    "biomejs",
    "bitwise",
    "blit",
    "bmfont",
    "Bresenham",
    "BTAPI",
    "btfont",
    "Chebyshev",
    "Cietwierkowski",
    "commitlint",
    "daafu",
    "dbaeumer",
    "dco",
    "esbuild",
    "gamepad",
    "Hiero",
    "indexization",
    "indexize",
    "indexized",
    "indexizes",
    "indexizing",
    "lcov",
    "lerp",
    "millis",
    "nsis",
    "PICO",
    "pico",
    "Playwright",
    "pnpm",
    "rects",
    "reindexize",
    "reindexizing",
    "retroblit",
    "RGBA",
    "rgba8unorm",
    "Rollup",
    "RRGGBB",
    "RRGGBBAA",
    "spritesheet",
    "subsystem",
    "subsystems",
    "timestep",
    "Uints",
    "unflushed",
    "unorm",
    "unstub",
    "Vančura",
    "Vite",
    "Vitest",
    "Václav",
    "WebGPU",
    "WGSL",
    "xadvance",
    "xoffset",
    "yoffset"
  ],
  "flagWords": ["cant", "dont", "hte", "teh", "wont"],
  "ignorePaths": ["*.map", "*.min.js", ".git", ".pnpm-store", "coverage", "dist", "node_modules", "pnpm-lock.yaml"],
  "ignoreRegExpList": ["/#[0-9A-Fa-f]{3,8}/", "/0x[0-9A-Fa-f]+/", "/@[a-zA-Z0-9_-]+\\/[a-zA-Z0-9_-]+/"],
  "overrides": [
    {
      "filename": "**/*.ts",
      "words": ["instanceof", "keyof", "readonly", "typeof"]
    }
  ]
}
