{
  "tab_size": 4,
  "hard_tabs": false,
  "preferred_line_length": 120,
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "wrap_guides": [120],
  "formatter": {
    "external": {
      "command": "biome",
      "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
    }
  },
  "code_actions_on_format": {
    "source.organizeImports": true,
    "source.fixAll": true
  },
  "languages": {
    "TypeScript": {
      "tab_size": 4,
      "preferred_line_length": 120,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    },
    "JavaScript": {
      "tab_size": 4,
      "preferred_line_length": 120,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "tab_size": 2
    },
    "CSS": {
      "tab_size": 4,
      "preferred_line_length": 100,
      "format_on_save": "on"
    },
    "Markdown": {
      "tab_size": 2,
      "preferred_line_length": 120,
      "formatter": "prettier"
    },
    "YAML": {
      "tab_size": 2,
      "preferred_line_length": 120,
      "formatter": "prettier"
    },
    "WGSL": {
      "tab_size": 4,
      "preferred_line_length": 120
    }
  },
  "lsp": {
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "importModuleSpecifierPreference": "relative"
        }
      }
    }
  },
  "git": {
    "inline_blame": {
      "enabled": true
    }
  },
  "journal": {
    "hour_format": "hour24"
  }
}
